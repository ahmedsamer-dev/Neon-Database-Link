{
  "framework": "vite",
  "buildCommand": "pnpm install && PORT=3000 BASE_PATH=/ pnpm --filter @workspace/peace run build",
  "outputDirectory": "artifacts/peace/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
